{
  "name": "fluentai-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone desktop shell for FluentAI.",
  "main": "desktop/electron/main.js",
  "scripts": {
    "desktop": "electron .",
    "build:app": "./scripts/build_mac_app.sh",
    "app": "./scripts/build_mac_app.sh && open dist/FluentAI.app",
    "test:python": "python -m unittest discover -s tests -q",
    "test:js": "node --check desktop/electron/main.js && node --check desktop/electron/preload.js && node --check mockups/duolingo-inspired/render-screenshots.js",
    "smoke": "python scripts/smoke_demo.py",
    "check": "npm run test:js && npm run test:python && npm run smoke",
    "package:bridge": "./scripts/build_bridge.sh"
  },
  "devDependencies": {
    "electron": "^39.2.4"
  }
}
