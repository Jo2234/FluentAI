# FluentAI local configuration
# Required for real Lesson Mode and Conversation Mode runs.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low
OPENAI_VERBOSITY=low

# Optional voice / camera model overrides for the desktop app.
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=alloy
# Tune voice turn-taking; omit these to use dynamic defaults based on level/confidence.
# OPENAI_REALTIME_SILENCE_MS=2500
# OPENAI_REALTIME_IDLE_PROMPT_MS=6500
# OPENAI_REALTIME_VAD_THRESHOLD=0.65
# Fast default vision model for live camera context.
OPENAI_VISION_MODEL=gpt-4.1-mini
